APP_NAME="Cafe CNS - Sistem Informasi Manajemen"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cafe_cns
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# WhatsApp Business API (opsional, untuk broadcast ke petani)
WA_API_URL=https://api.whatsapp-gateway.example.com
WA_API_KEY=your_wa_api_key_here
WA_SENDER_NUMBER=628xxxxxxxxxx
